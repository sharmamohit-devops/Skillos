# MirrorFish Configuration
MIRRORFISH_BASE_URL=http://localhost:5001
MIRRORFISH_NUM_ROUNDS=15
MIRRORFISH_TIMEOUT=30

# MirrorFish API Keys (if required by your MirrorFish instance)
# Leave empty if MirrorFish doesn't require authentication
MIRRORFISH_API_KEY=

# Optional: MirrorFish Authentication
MIRRORFISH_USERNAME=admin
MIRRORFISH_PASSWORD=

# Optional: MirrorFish Advanced Settings
MIRRORFISH_MAX_RETRIES=3
MIRRORFISH_RETRY_DELAY=5
MIRRORFISH_ENABLE_HEARTBEAT=true